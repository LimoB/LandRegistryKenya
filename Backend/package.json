{
  "name": "land-registry-backend",
  "version": "1.0.0",
  "description": "Kenyan Land Registry Blockchain Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "gen": "drizzle-kit generate",
    "push": "drizzle-kit generate && drizzle-kit push",
    "studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "seed": "tsx src/drizzle/seed.ts",
    "seed:reset": "tsx src/drizzle/seed.ts --reset"
  },
  "keywords": [
    "blockchain",
    "land-registry",
    "drizzle",
    "ethereum",
    "kenya"
  ],
  "author": "Boaz Lee-Limo",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^7.1.1",
    "stripe": "^22.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "web3": "^4.16.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.18.0",
    "@types/stripe": "^8.0.417",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}